#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('thuvienso:server');
var http = require('http');

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

// --- BẮT ĐẦU CẤU HÌNH SOCKET.IO CHO CHAT REALTIME ---
const { Server } = require("socket.io");
const io = new Server(server, {
  cors: {
    origin: "*", // Cho phép ReactJS gọi tới mà không bị chặn (Lỗi CORS)
    methods: ["GET", "POST"]
  }
});

const Message = require('../schemas/messages'); // Gọi khuôn đúc ra để lưu DB

// Lắng nghe khi có người dùng truy cập vào trang web
io.on('connection', (socket) => {
  console.log('⚡ Một người dùng vừa kết nối chat. ID:', socket.id);

  // Lắng nghe sự kiện người dùng bấm gửi tin nhắn
  socket.on('send_message', async (data) => {
    try {
      // 1. Lưu tin nhắn vào Database để không bị mất
      const newMessage = await Message.create({
        sender: data.sender, // data.sender là ID của người dùng
        content: data.content
      });

      // 2. Kéo thêm thông tin Tên của người gửi để hiện lên khung chat
      const populatedMessage = await Message.findById(newMessage._id).populate('sender', 'fullName username');

      // 3. Phép thuật đây: Phát trực tiếp tin nhắn này đến TẤT CẢ mọi người đang online
      io.emit('receive_message', populatedMessage);
      
    } catch (error) {
      console.log("❌ Lỗi khi lưu tin nhắn chat:", error);
    }
  });

  // Lắng nghe khi người dùng tắt web
  socket.on('disconnect', () => {
    console.log('💤 Một người dùng đã rời khỏi phòng chat. ID:', socket.id);
  });
});
// --- KẾT THÚC CẤU HÌNH SOCKET.IO ---

/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
}
